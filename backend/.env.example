# ─────────────────────────────────────────────────────────────────────────────
# IDXSOC — Environment Configuration
# Copy this file to .env and fill in your actual credentials.
# The backend reads these automatically via python-dotenv (or plain env vars).
# ─────────────────────────────────────────────────────────────────────────────

# ── SMTP (Email Alerts) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password         # For Gmail: use an App Password, not your login password

# The "From" address shown in alert emails (defaults to SMTP_USERNAME if blank)
ALERT_FROM=idxsoc-noreply@yourdomain.com

# The security team email that receives all threat alerts
ALERT_RECIPIENT=secops@yourdomain.com

# ── Slack (Webhook Alerts) ─────────────────────────────────────────────────────
# Create an Incoming Webhook at https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK=https://hooks.slack.com/services/T000/B000/XXXX

# ── Mailtrap (Advanced API Method) ───────────────────────────────────────────
# Set to 'mailtrap' to use the API, or 'smtp' for traditional SMTP
EMAIL_PROVIDER=smtp
MAILTRAP_TOKEN=your-mailtrap-api-token
MAILTRAP_SENDER_EMAIL=alerts@your-verified-domain.com
MAILTRAP_SENDER_NAME="IDXSOC Alerts"
