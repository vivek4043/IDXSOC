# ─────────────────────────────────────────────────────────────────────────────
# IDXSOC — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in real values below (never commit .env to git)
#   3. Restart the backend after editing
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas (REQUIRED) ───────────────────────────────────────────────────
# Get this from: Atlas Dashboard → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=idxsoc

# How many days to keep logs/threats before TTL auto-deletion (default: 15)
DATA_RETENTION_DAYS=15

# ── JWT (REQUIRED) ─────────────────────────────────────────────────────────────
# Generate with:  python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-64-char-hex-secret
JWT_EXPIRE_HOURS=8

# ── Admin Account (seeded on first run if DB is empty) ────────────────────────
# Change these BEFORE the first run — they cannot be changed after seeding
# without clearing the users collection.
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-before-first-run

# ── Email Alerts (SMTP) ────────────────────────────────────────────────────────
# Leave SMTP_USERNAME/PASSWORD blank to disable email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password        # Gmail: use an App Password, not your login password

# "From" address in alert emails (falls back to SMTP_USERNAME if blank)
ALERT_FROM=idxsoc-noreply@yourdomain.com

# Security team inbox that receives threat alerts
ALERT_RECIPIENT=secops@yourdomain.com

# ── Slack (Webhook Alerts) ─────────────────────────────────────────────────────
# Create at: https://api.slack.com/messaging/webhooks
# Paste your full webhook URL here. Leave blank to disable Slack alerts.
# Format: https://hooks.slack.com/services/<T...>/<B...>/<token>
SLACK_WEBHOOK=

# ── Email Provider ─────────────────────────────────────────────────────────────
# Set to 'mailtrap' to use Mailtrap API, or 'smtp' for standard SMTP
EMAIL_PROVIDER=smtp

# ── Mailtrap API (optional, only when EMAIL_PROVIDER=mailtrap) ────────────────
MAILTRAP_TOKEN=your-mailtrap-api-token
MAILTRAP_SENDER_EMAIL=alerts@your-verified-domain.com
MAILTRAP_SENDER_NAME=IDXSOC Alerts
